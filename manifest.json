{
  "manifest_version": 3,
  "name": "ChatKOOL Message Notification Extension",
  "version": "1.0.0",
  "description": "A ChatKOOL web extension that notifies you when someone messages",
  "content_scripts": [
    {
      "matches": [
        "https://*.chatkool.com/*"
      ],
      "js": [
        "scripts/app.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://*.chatkool.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/favicon-16.png",
    "32": "icons/favicon-32.png",
    "48": "icons/favicon-48.png",
    "128": "icons/favicon-128.png"
  }
}